    {
      "id": "DXwjLfwCbv8zxyztHbEMU",
      "type": "text",
      "x": -271.9331094225588,
      "y": 138.62652497266004,
      "width": 843.4300537109375,
      "height": 435.72070312499983,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a0",
      "roundness": null,
      "seed": 1312300367,
      "version": 1512,
      "versionNonce": 2103671905,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782183075837,
      "link": null,
      "locked": false,
      "text": "Design Tinder - Match Aggregator Tool - Allows people to match with recommended people on the app\nswipe left or right on a profile, uses location data and user specified filters to suggest potential matches nearby\n\nFunctional Requirements:\nusers set their preference\nusers can veiw a stack of potential matches\n    - match preferences\n    - recommended matches\n    - close to current location\nusers can swipe left or right\n2 users swipe right, or left\n\nConstraint:\n- avoid showing repeat profiles\n\nNon Functional Requirements:\n- Consistency for swipes \n(because instant notification for matches - some user swiped right on current user)\n- low latency feeds (< 200ms - 500ms)\n- scalable to 10M DAU - handle high write throughput\n\n\n",
      "fontSize": 15.155502717391299,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Design Tinder - Match Aggregator Tool - Allows people to match with recommended people on the app\nswipe left or right on a profile, uses location data and user specified filters to suggest potential matches nearby\n\nFunctional Requirements:\nusers set their preference\nusers can veiw a stack of potential matches\n    - match preferences\n    - recommended matches\n    - close to current location\nusers can swipe left or right\n2 users swipe right, or left\n\nConstraint:\n- avoid showing repeat profiles\n\nNon Functional Requirements:\n- Consistency for swipes \n(because instant notification for matches - some user swiped right on current user)\n- low latency feeds (< 200ms - 500ms)\n- scalable to 10M DAU - handle high write throughput\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
