    {
      "id": "GvBJl2VG4FVRmk7oEe2rO",
      "type": "text",
      "x": -245.83072916666663,
      "y": 617.72265625,
      "width": 271.103759765625,
      "height": 340,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a3",
      "roundness": null,
      "seed": 223108449,
      "version": 463,
      "versionNonce": 1585414177,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782180280935,
      "link": null,
      "locked": false,
      "text": "API\nPOST /profiles -> Profile\n{\n    minAge,\n    maxAge,\n    locationRadius,\n    ethnicity, etc..\n}\n\nGET /stacks?lat&long -> Profile[]\nHeader: JWT | session\n\nPOST /swipes/userId -> Match\nHeader: JWT | session\n{\n    decision: yes | right\n}",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API\nPOST /profiles -> Profile\n{\n    minAge,\n    maxAge,\n    locationRadius,\n    ethnicity, etc..\n}\n\nGET /stacks?lat&long -> Profile[]\nHeader: JWT | session\n\nPOST /swipes/userId -> Match\nHeader: JWT | session\n{\n    decision: yes | right\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
