    {
      "id": "AxDacTPj4ZzVn7QRX3_7g",
      "type": "text",
      "x": 914.414064950353,
      "y": 7.558517474430829,
      "width": 554.303466796875,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aU",
      "roundness": null,
      "seed": 1401203617,
      "version": 479,
      "versionNonce": 2095045423,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782180986095,
      "link": null,
      "locked": false,
      "text": "10M (users) * 100 (swipes) = 1B Swipes Per day\n1B / 100k (seconds per day) = 10k swipes per second - daily swipes\n10k swipes  * 10 = 100k Swipes/second - during peak hours\n\nPostgres DB  - 10k writes per second or per node\n1KB total doc suze\nCassandra is write optimized - so better to user for high write service\n\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "10M (users) * 100 (swipes) = 1B Swipes Per day\n1B / 100k (seconds per day) = 10k swipes per second - daily swipes\n10k swipes  * 10 = 100k Swipes/second - during peak hours\n\nPostgres DB  - 10k writes per second or per node\n1KB total doc suze\nCassandra is write optimized - so better to user for high write service\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
